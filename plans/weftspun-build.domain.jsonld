{
  "@context": {"weftspun": "https://github.com/weftspun/", "domain": "weftspun:planning/domain/"},
  "@type": "domain:Definition",
  "name": "weftspun_hexagonal_buildout",
  "description": "HTN plan (taskweft) for building the weftspun org's hexagonal clusters. Each action = scaffold + test + ship one Elixir/Burrito repo (core/ports/adapters), MIT-OR-Apache-2.0 + SPDX. done/* seeds completed work. Dependencies follow the ETNF wiring: everything writes to / reads from `essential-tuple-lake` (the store at the bottom of the stack). ML clusters embed Python via Pythonx and native Lean/C via Fine, meeting at .sigs ports; pure-Elixir clusters (lake, ingest) use Explorer. Durations are ISO8601, calibrated to AI wall-clock.",
  "variables": [
    {"name": "done", "init": {
      "lake": true,
      "ingest": true,
      "embedder": false,
      "render": false,
      "slat": false,
      "phenotype": false,
      "oracle": false
    }}
  ],
  "actions": {
    "a_lake":      {"params": [], "duration": "PT1H", "platform": "elixir", "repo": "essential-tuple-lake",   "body": [{"set": "/done/lake", "value": true}]},
    "a_ingest":    {"params": [], "duration": "PT1H", "platform": "elixir", "repo": "corpus-relation-ingest",  "body": [{"check": "/done/lake", "eq": true}, {"set": "/done/ingest", "value": true}]},
    "a_embedder":  {"params": [], "duration": "PT2H", "platform": "pythonx","repo": "unified-modal-embedder",  "body": [{"check": "/done/lake", "eq": true}, {"set": "/done/embedder", "value": true}]},
    "a_render":    {"params": [], "duration": "PT2H", "platform": "pythonx","repo": "headless-viser-render",   "body": [{"check": "/done/lake", "eq": true}, {"set": "/done/render", "value": true}]},
    "a_slat":      {"params": [], "duration": "PT2H", "platform": "pythonx","repo": "voxel-slat-encoder",      "body": [{"check": "/done/lake", "eq": true}, {"set": "/done/slat", "value": true}]},
    "a_phenotype": {"params": [], "duration": "PT3H", "platform": "fine",   "repo": "pose-anny-phenotype",     "body": [{"check": "/done/lake", "eq": true}, {"check": "/done/render", "eq": true}, {"set": "/done/phenotype", "value": true}]},
    "a_oracle":    {"params": [], "duration": "PT3H", "platform": "pythonx","repo": "semantic-code-oracle",    "body": [{"check": "/done/lake", "eq": true}, {"check": "/done/ingest", "eq": true}, {"check": "/done/embedder", "eq": true}, {"check": "/done/slat", "eq": true}, {"set": "/done/oracle", "value": true}]}
  },
  "methods": {
    "m_lake":      {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/lake",      "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_lake"]]}]},
    "m_ingest":    {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/ingest",    "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_ingest"]]}]},
    "m_embedder":  {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/embedder",  "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_embedder"]]}]},
    "m_render":    {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/render",    "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_render"]]}]},
    "m_slat":      {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/slat",      "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_slat"]]}]},
    "m_phenotype": {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/phenotype", "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_phenotype"]]}]},
    "m_oracle":    {"params": [], "alternatives": [{"name": "skip", "check": [{"pointer": "/done/oracle",    "eq": true}], "subtasks": []}, {"name": "do", "subtasks": [["a_oracle"]]}]},

    "buildout": {"params": [], "alternatives": [{"name": "do", "subtasks": [["m_lake"], ["m_ingest"], ["m_embedder"], ["m_render"], ["m_slat"], ["m_phenotype"], ["m_oracle"]]}]}
  },
  "tasks": [["buildout"]]
}
